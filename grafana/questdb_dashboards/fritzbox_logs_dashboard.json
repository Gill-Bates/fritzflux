          "queryType": "sql",
          "rawSql": "SELECT timestamp AS \"Date/Time\", log_type AS \"Log Type\", log_entry AS \"Entry\"\nFROM ${measurement}\nWHERE $__timeFilter(timestamp)\n  AND box ~ '^${boxtag:regex}$'\n  AND log_entry IS NOT NULL\n  AND log_type ~ '^${log_type:regex}$'\nORDER BY timestamp DESC",
