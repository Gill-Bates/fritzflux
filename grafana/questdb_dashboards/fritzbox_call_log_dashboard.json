        {
          "datasource": {
            "type": "questdb-questdb-datasource",
            "uid": "${DS_QUESTDB}"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT timestamp AS \"Time\",\n  last_not_null(call_list_type) AS \"Call Type\",\n  last_not_null(call_list_caller_number) AS \"Number\",\n  last_not_null(call_list_caller_name) AS \"Name\",\n  last_not_null(call_list_duration) AS \"Duration\",\n  last_not_null(call_list_extension) AS \"Extension\",\n  last_not_null(call_list_number_called) AS \"Number called\"\nFROM ${measurement}\nWHERE $__timeFilter(timestamp)\n  AND box ~ '^${boxtag:regex}$'\n  AND (\n    call_list_type IS NOT NULL OR\n    call_list_caller_number IS NOT NULL OR\n    call_list_caller_name IS NOT NULL OR\n    call_list_duration IS NOT NULL OR\n    call_list_extension IS NOT NULL OR\n    call_list_number_called IS NOT NULL\n  )\nGROUP BY timestamp, uid\nORDER BY timestamp DESC",
          "refId": "A",
          "selectedFormat": 1
        }
      ],
      "title": "Call List Entries",
      "transformations": [
