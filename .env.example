# =============================================================================
# fritzFlux - Environment Configuration Template
# =============================================================================
# Copy this file to ".env" and customize the values for your setup.
# Most variables can also be configured in the fritzFlux.ini file.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. General Daemon Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
TZ=Europe/Berlin

# -----------------------------------------------------------------------------
# 2. FritzBox Configuration
# -----------------------------------------------------------------------------
FRITZBOX_HOSTNAME="192.168.178.1"
FRITZBOX_USERNAME="<your-fritzbox-username>"
FRITZBOX_PASSWORD="<your-fritzbox-password>"

# Optional FritzBox settings (defaults shown)
# FRITZBOX_PORT=49000
# FRITZBOX_TLS_ENABLED=False
# FRITZBOX_VERIFY_TLS=False
# FRITZBOX_CONNECT_TIMEOUT=10
# FRITZBOX_REQUEST_INTERVAL=10
# FRITZBOX_BOX_TAG="fritz.box"
# FRITZBOX_TIMEZONE="Europe/Berlin"

# -----------------------------------------------------------------------------
# 3. Database Provider Selection
# -----------------------------------------------------------------------------
# Choose the database type: "influxdb_v1", "influxdb_v2" (default) or "questdb"
DB_TYPE=influxdb_v2

# -----------------------------------------------------------------------------
# 4. InfluxDB Configuration (used when DB_TYPE=influxdb_v1 or influxdb_v2)
# -----------------------------------------------------------------------------
# Hostname may also be a full URL (e.g. "https://influx.example.com" behind a
# reverse proxy) - protocol and port are detected automatically.
INFLUXDB_HOSTNAME="<your-influxdb-hostname>"
INFLUXDB_PORT=8086
# INFLUXDB_TLS_ENABLED=False
# INFLUXDB_VERIFY_TLS=True
# INFLUXDB_MEASUREMENT_NAME="fritzbox"

# Allow sending credentials/token over plain HTTP (trusted home networks only)
# INFLUXDB_ALLOW_PLAINTEXT_CREDENTIALS=True

# --- InfluxDB v1 Specific Settings ---
# INFLUXDB_DATABASE="<my-database>"
# INFLUXDB_USERNAME="<v1-username>"
# INFLUXDB_PASSWORD="<v1-password>"

# --- InfluxDB v2 Specific Settings ---
INFLUXDB_ORGANIZATION="<my-org>"
INFLUXDB_BUCKET="<my-bucket>"
INFLUXDB_TOKEN="<my-v2-token>"

# -----------------------------------------------------------------------------
# 5. QuestDB Configuration (used when DB_TYPE=questdb)
# -----------------------------------------------------------------------------
# QUESTDB_HOSTNAME="<your-questdb-hostname>"
# QUESTDB_PORT=9000
# QUESTDB_TLS_ENABLED=False
# QUESTDB_VERIFY_TLS=True
# QUESTDB_MEASUREMENT_NAME="fritzbox"

# --- QuestDB Authentication (Optional) ---
# QUESTDB_USERNAME="<questdb-username>"
# QUESTDB_PASSWORD="<questdb-password>"
# QUESTDB_TOKEN="<questdb-bearer-token>"

# Allow sending credentials/token over plain HTTP (trusted home networks only)
# QUESTDB_ALLOW_PLAINTEXT_CREDENTIALS=True
